# ~/.zshrc — interactive zsh config

# ---- History ----
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000
setopt SHARE_HISTORY HIST_IGNORE_ALL_DUPS HIST_IGNORE_SPACE INC_APPEND_HISTORY

# ---- Behaviour ----
setopt AUTO_CD              # type a dir name to cd into it
setopt INTERACTIVE_COMMENTS # allow # comments in interactive shell

# ---- Completion ----
fpath=(/usr/share/zsh/site-functions $fpath)
autoload -Uz compinit && compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-zA-Z}={A-Za-z}'  # case-insensitive

# ---- Aliases (ported from bash) ----
alias ls='ls --color=auto'
alias grep='grep --color=auto'

# ---- PATH ----
export PATH="$HOME/.local/bin:$PATH"

# ---- Autosuggestions ----
# Suggest from history first, then fall back to tab-completion (works even with empty history)
ZSH_AUTOSUGGEST_STRATEGY=(history completion)
source /usr/share/zsh/plugins/zsh-autosuggestions/zsh-autosuggestions.zsh 2>/dev/null

# ---- fzf (Ctrl-R history, Ctrl-T files, Alt-C cd, **<Tab>) ----
if command -v fzf >/dev/null 2>&1; then
    eval "$(fzf --zsh)"
fi

# ---- Prompt ----
if command -v starship >/dev/null 2>&1; then
    eval "$(starship init zsh)"
fi

# ---- Syntax highlighting (MUST be sourced last) ----
source /usr/share/zsh/plugins/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh 2>/dev/null
